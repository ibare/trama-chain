{
  "name": "@trama/host-tiptap-bundle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-contained ESM bundle of @trama/host-tiptap + projector-web + core + fizzex. 메티 등 외부 호스트 앱에서 단일 의존(file: tarball)으로 소비.",
  "main": "./dist/host-tiptap-bundle.js",
  "types": "./dist/host-tiptap-bundle.d.ts",
  "exports": {
    ".": {
      "types": "./dist/host-tiptap-bundle.d.ts",
      "import": "./dist/host-tiptap-bundle.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "build:analyze": "VISUALIZE=1 rollup -c rollup.config.mjs",
    "typecheck": "tsc --noEmit",
    "pack": "pnpm build && npm pack"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "fizzex": "^0.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-replace": "^6.0.1",
    "@tiptap/core": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@trama/host-tiptap": "workspace:*",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "fizzex": "^0.1.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "rollup": "^4.28.0",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-esbuild": "^6.1.1",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-visualizer": "^5.12.0",
    "typescript": "5.6.3"
  }
}

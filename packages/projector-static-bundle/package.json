{
  "name": "@trama-chain/static-projector",
  "version": "0.1.1",
  "type": "module",
  "description": "Static SVG viewer for Trama model snapshots. Zero-compute deterministic rendering — PDF, thumbnail, embed preview.",
  "license": "MIT",
  "author": "ibare",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ibare/trama-chain.git",
    "directory": "packages/projector-static-bundle"
  },
  "homepage": "https://github.com/ibare/trama-chain#readme",
  "bugs": "https://github.com/ibare/trama-chain/issues",
  "keywords": [
    "trama",
    "static",
    "snapshot",
    "svg",
    "viewer",
    "graph"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/static-projector.js",
  "types": "./dist/static-projector.d.ts",
  "exports": {
    ".": {
      "types": "./dist/static-projector.d.ts",
      "import": "./dist/static-projector.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "build:analyze": "VISUALIZE=1 rollup -c rollup.config.mjs",
    "typecheck": "tsc --noEmit",
    "pack": "pnpm build && npm pack"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-replace": "^6.0.1",
    "@trama-chain/projector-static": "workspace:*",
    "@types/react": "19.2.0",
    "react": "19.2.0",
    "rollup": "^4.28.0",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-esbuild": "^6.1.1",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-visualizer": "^5.12.0",
    "typescript": "5.6.3"
  }
}

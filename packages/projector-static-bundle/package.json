{
  "name": "@trama/projector-static-bundle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-contained ESM bundle of @trama/projector-static + core + layout + tokens. 메티 등 외부 호스트 앱에서 PDF·썸네일·정적 미리보기 시나리오에 단일 의존으로 소비.",
  "main": "./dist/projector-static-bundle.js",
  "types": "./dist/projector-static-bundle.d.ts",
  "exports": {
    ".": {
      "types": "./dist/projector-static-bundle.d.ts",
      "import": "./dist/projector-static-bundle.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "build:analyze": "VISUALIZE=1 rollup -c rollup.config.mjs",
    "typecheck": "tsc --noEmit",
    "pack": "pnpm build && npm pack"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-replace": "^6.0.1",
    "@trama/projector-static": "workspace:*",
    "@types/react": "19.2.0",
    "react": "19.2.0",
    "rollup": "^4.28.0",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-esbuild": "^6.1.1",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-visualizer": "^5.12.0",
    "typescript": "5.6.3"
  }
}

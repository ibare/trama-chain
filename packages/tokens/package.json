{
  "name": "@trama-chain/tokens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/tokens.js",
  "module": "./dist/tokens.js",
  "types": "./dist/tokens.d.ts",
  "exports": {
    ".": {
      "import": "./dist/tokens.js",
      "types": "./dist/tokens.d.ts"
    },
    "./css": "./dist/tokens.scoped.css",
    "./raw": "./src/tokens.json"
  },
  "files": [
    "dist",
    "src/tokens.json"
  ],
  "scripts": {
    "build": "tsx build.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  }
}

{
  "name": "trama",
  "version": "0.1.0",
  "private": true,
  "description": "Trama — 관계를 함수 형태로 정의하는 프레이밍 도구",
  "scripts": {
    "build": "pnpm -r --filter './packages/**' run build",
    "build:tokens": "pnpm --filter @trama/tokens run build",
    "test": "pnpm -r --filter './packages/**' run test",
    "test:run": "pnpm -r --filter './packages/**' run test:run",
    "typecheck": "pnpm -r --filter './packages/**' run typecheck",
    "dev": "pnpm --filter @trama/website run dev",
    "dev:site": "pnpm --filter @trama/website run dev",
    "build:site": "pnpm --filter @trama/website run build",
    "lint": "pnpm -r run lint",
    "postinstall": "pnpm --filter @trama/tokens run build"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "vitest": "2.1.4",
    "@types/node": "22.9.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.27.0"
}
